// Single-household prototype: everything hangs off one Household row,
// seeded by prisma/seed.js. Multi-household / auth is a later step —
// the shape below already supports it (everything is scoped by householdId),
// it's just not enforced by an auth layer yet.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  reminders      Reminder[]
  activityEvents ActivityEvent[]
  elderProfile   ElderProfile?
}

model ElderProfile {
  id          String    @id @default(cuid())
  name        String
  household   Household @relation(fields: [householdId], references: [id])
  householdId String    @unique
}

model Reminder {
  id        String    @id @default(cuid())
  task      String
  time      String // "HH:MM", 24h — kept as string to match the <input type="time"> value directly
  frequency Frequency
  createdAt DateTime  @default(now())

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  events ActivityEvent[]
}

enum Frequency {
  Daily
  Weekly
}

model ActivityEvent {
  id         String    @id @default(cuid())
  kind       EventKind
  label      String
  occurredAt DateTime  @default(now())

  household   Household @relation(fields: [householdId], references: [id])
  householdId String

  reminder   Reminder? @relation(fields: [reminderId], references: [id])
  reminderId String?
}

enum EventKind {
  prompt
  confirmed
  declined
  alert
}
